# AgentForge AI - Environment Configuration
# Copy this file to .env and fill in your values
# For development: most defaults work out of the box
# For production: fill in all IMPORTANT values

# ============================================
# APPLICATION SETTINGS
# ============================================
APP_NAME=AgentForge AI
APP_VERSION=1.0.0
DEBUG=true                          # Set to false in production
DEMO_MODE=true                      # Set to false when using real API keys

# ============================================
# SECURITY (IMPORTANT: Change in production)
# ============================================
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-super-secret-key-change-in-production-12345
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOURS=24
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================
# API CONFIGURATION
# ============================================
API_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://127.0.0.1:3000"]

# ============================================
# FRONTEND
# ============================================
VITE_API_URL=http://localhost:8000/api/v1
VITE_WS_URL=ws://localhost:8000

# ============================================
# DATABASE
# ============================================
# Development (SQLite - works out of the box)
DATABASE_URL=sqlite+aiosqlite:///./agentforge.db

# Production (PostgreSQL)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/agentforge_db

# ============================================
# CACHE & MEMORY
# ============================================
# Redis (optional - for distributed caching)
# REDIS_URL=redis://localhost:6379/0

# ChromaDB (vector store)
CHROMADB_HOST=localhost
CHROMADB_PORT=8000

# ============================================
# LLM PROVIDERS (Optional)
# ============================================
# OpenAI
OPENAI_API_KEY=sk-...

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Model settings
DEFAULT_LLM_MODEL=gpt-4o
DEFAULT_LLM_TEMPERATURE=0.1

# ============================================
# MONITORING & LOGGING
# ============================================
LOG_LEVEL=INFO

# Sentry (optional - error tracking)
# SENTRY_DSN=https://...@sentry.io/...

# ============================================
# WORKFLOW SETTINGS
# ============================================
MAX_WORKFLOW_RUNTIME=3600           # seconds
MAX_AGENTS_PER_WORKFLOW=50
WORKFLOW_TIMEOUT_SECONDS=300

# ============================================
# FEATURE FLAGS
# ============================================
ENABLE_ANALYTICS=true
ENABLE_APPROVALS=true
ENABLE_REPORTS=true
ENABLE_AUDIT_LOG=true
