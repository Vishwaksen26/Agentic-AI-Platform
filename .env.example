# Environment Variables Example
# Copy this file to .env and fill in your values

# ─── App ────────────────────────────────────────────────────────────────────
APP_NAME="AgentForge AI"
APP_VERSION="1.0.0"
DEBUG=true
DEMO_MODE=true  # Set to false when using real API keys

# ─── Frontend ───────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000/api/v1
VITE_WS_URL=ws://localhost:8000

# ─── Security ────────────────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-change-in-production-min-32-chars

# ─── LLM Providers (optional - demo mode works without these) ─────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
DEFAULT_LLM_MODEL=gpt-4o
DEFAULT_LLM_TEMPERATURE=0.1

# ─── Database ────────────────────────────────────────────────────────────────
# If not set, uses SQLite automatically (great for local dev)
# POSTGRES_URL=postgresql+asyncpg://user:password@localhost:5432/agentforge

# ─── Redis (optional - memory works in-process without this) ─────────────────
# REDIS_URL=redis://localhost:6379

# ─── ChromaDB (optional - vector search works with in-memory fallback) ────────
CHROMADB_HOST=localhost
CHROMADB_PORT=8001

# ─── Authentication (optional - demo mode bypasses auth) ─────────────────────
# CLERK_SECRET_KEY=sk_...
# CLERK_PUBLISHABLE_KEY=pk_...
